alias exe_remove="chmod -x"
alias perm_rwx="chmod 755"
alias perm_private="chmod 700"
alias perm_public="chmod 755"

# Ownership Batch
alias recursive_own="chown -R"
alias recursive_grp="chgrp -R"

# ─────────────────────────────────────────────────────────────────────────────
# ARCHIVIERUNG & KOMPRESSION
# ─────────────────────────────────────────────────────────────────────────────

# TAR Basics
alias tar_create="tar -czvf"
alias tar_extract="tar -xzvf"
alias tar_list="tar -tzvf"
alias tar_bz="tar -cjvf"

# ZIP Operations
alias zip_file="zip -r"
alias unzip_file="unzip"
alias zip_ls="zipinfo"

# 7ZIP (benötigt p7zip-full)
alias sevenz_pack="7z a"
alias sevenz_unpack="7z x"
alias sevenz_test="7z t"
alias sevenz_list="7z l"

# Compressed View
alias gz_cat="zcat"
alias bz_cat="bzcat"
alias xz_cat="xzcat"

# ─────────────────────────────────────────────────────────────────────────────
# GEWINNER: QUICK COMMAND FIXES
# ─────────────────────────────────────────────────────────────────────────────

# Root Fehler Korrektur
alias bitte="sudo \$(history -p !!)"
alias fuck="sudo \$(history -p !!)"
alias please="sudo \$(history -p !!)"
