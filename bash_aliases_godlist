# Path anzeigen
alias path_display="echo -e \${PATH//:/\\n}"
alias env_vars="env | sort"
alias print_env="printenv"

# Zufällig Generieren
alias random_pw="openssl rand -base64 32"
alias random_hex="openssl rand -hex 32"
alias random_str="date +%s | sha256sum | base64 | head -c 32"

# Uhrzeit & Datum
alias date_now="date '+%Y-%m-%d %H:%M:%S'"
alias cal_view="cal"
alias cal_year="ncal -y"
alias timezone="timedatectl"

# Fun Commands
alias matrix="cmatrix -b"
alias moo="apt-get moo"
alias fortune_cookie="fortune"
alias cowsay_text="cowsay"
alias banner_msg="banner"

