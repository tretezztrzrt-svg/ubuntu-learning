#!/usr/bin/env bash
set -euo pipefail

max_size=1048576
exit_code=0

sensitive_patterns=(
  'PASSWORD'
  'PASSWORT'
  'API_KEY'
  'SECRET'
  'SECRET_KEY'
  'PRIVATE_KEY'
  'AWS_ACCESS_KEY_ID'
  'AWS_SECRET_ACCESS_KEY'
  'TOKEN'
  'KEY='
)

function report_large_files() {
  local range="$1"
  git rev-list --objects "$range" 2>/dev/null |
    git cat-file --batch-check='%(objecttype) %(objectsize) %(rest)' 2>/dev/null |
    while IFS= read -r line; do
      object_type=${line%% *}
      rest=${line#* }
      object_size=${rest%% *}
      object_path=${rest#* }

      if [[ "$object_type" == "blob" ]] && (( object_size > max_size )); then
        printf 'ERROR: Large file in push (%d bytes): %s\n' "$object_size" "$object_path"
        exit_code=1
      fi
    done
}

function report_sensitive_content() {
  local commit="$1"
  local file
  local pattern_file

  pattern_file=$(mktemp)
  trap 'rm -f "$pattern_file"' RETURN
  printf '%s\n' "${sensitive_patterns[@]}" > "$pattern_file"

  while IFS= read -r file; do
    [[ -z "$file" ]] && continue

    if git show "${commit}:$file" 2>/dev/null | grep -IEn --color=never -f "$pattern_file" >/dev/null 2>&1; then
      echo "ERROR: Sensitive content detected in commit $commit, file: $file"
      git show "${commit}:$file" 2>/dev/null | grep -IEn --color=never -f "$pattern_file" | sed 's/^/  /'
      exit_code=1
    fi
  done < <(
    git diff-tree --no-commit-id --name-only -r "$commit"
  )
}

while IFS= read -r local_ref local_sha remote_ref remote_sha; do
  [[ "$local_sha" == "0000000000000000000000000000000000000000" ]] && continue

  range="$remote_sha..$local_sha"
  [[ "$remote_sha" == "0000000000000000000000000000000000000000" ]] && range="$local_sha"

  report_large_files "$range"

  while IFS= read -r commit; do
    report_sensitive_content "$commit"
  done < <(git rev-list "$range")
done

if (( exit_code != 0 )); then
  echo
  echo "Push blocked because one or more conditions failed."
  echo "To enable this hook locally: git config core.hooksPath .githooks"
  exit 1
fi
