}

# Backup important configs quickly
function backup_configs() {
    local dest="${1:-./backup_$(date +%Y%m%d_%H%M%S)}"
    
    mkdir -p "$dest"
    
    echo "Creating config backups in: $dest"
    
    declare -a configs=(
        ".bashrc" ".bash_aliases" ".bash_functions"
        ".profile" ".vimrc" ".tmux.conf"
    )
    
    for conf in "${configs[@]}"; do
        [ -f "~/$conf" ] && cp -v "~/$conf" "$dest/" 2>/dev/null
    done
    
    # Add custom locations
    [ -d "/etc/nginx" ] && cp -rv "/etc/nginx" "$dest/etc_nginx" 2>/dev/null
    [ -f "/etc/fstab" ] && cp -v "/etc/fstab" "$dest/" 2>/dev/null
    
    echo "✅ Backup complete: $dest"
}

