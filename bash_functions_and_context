# Erstellen eines Ordners und sofortiges Wechseln hinein
function mkcd() {
    if [ -z "$1" ]; then
        echo "❌ usage: mkcd <directory_name>"
        return 1
    fi
    mkdir -p "$1" && cd "$1" && echo "✅ Created and entered: $1"
}

# Navigiere zur vorherigen Verzeichnisposition
function back() {
    cd - > /dev/null && pwd
}

# Gehe zum Home-Verzeichnis mit Info
function homedir() {
    cd ~ && echo "🏠 Home Directory: $PWD"
}

# Navigiere zu häufig genutzten Pfaden mit Parameter
function goto() {
    case "$1" in
        alex)  cd /home/alex/ ;;
        vera)  cd /media/veracrypt1/ ;;
        logs)  cd /var/log/ ;;
        doc)   cd ~/Documents/ ;;
        down)  cd ~/Downloads/ ;;
        etc)   cd /etc/ ;;
        tmp)   cd /tmp/ ;;
        root)  cd /root/ ;;
        dev)   cd ~/Development/ ;;
        projects) cd ~/projects/ ;;
        *) echo "❌ Unknown target '$1'. Valid options: alex, vera, logs, doc, down, etc, tmp, root, dev, projects" ;;
    esac
}

# Tree-like directory navigation
function treedir() {
    local depth="${2:-5}"
    find "$1" -maxdepth "$depth" -type d | sed 's:[^/]*/:  :g;s:.::;s:^--$:|:'
}

