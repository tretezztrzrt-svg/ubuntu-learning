# Schneller Systemstatus Overview
function sysinfo() {
    echo "=========================================="
    echo "        🖥️ SYSTEM INFORMATION 🖥️"
    echo "=========================================="
    
    echo -e "\n📅 Date & Uptime:"
    date "+%Y-%m-%d %H:%M:%S"
    uptime -p
    
    echo -e "\n💻 Hostname & Kernel:"
    hostname
    uname -r
    
    echo -e "\n👤 Logged Users:"
    who | wc -l
    who
    
    echo -e "\n📀 Disk Space (/):"
    df -h / | tail -1 | awk '{print "Used:", $3 "/" $2 " (" $5 ")"}'
    
    echo -e "\n🧠 Memory Usage:"
    free -h | grep Mem | awk '{print "Used:", $3 "/" $2 " (" int($3/$2*100) "%)"}'
    
    echo -e "\n🔥 Load Average:"
    cat /proc/loadavg | awk '{print "1m: "$1", 5m: "$2", 15m: "$3}'
    
    echo -e "\n🔋 CPU Temperature (if available):"
    if command -v sensors &> /dev/null; then
        sensors | grep -E "Core|Package" | head -5
    else
        echo "   (install lm-sensors for temps)"
    fi
    
    echo -e "\n=========================================="
}

