    shift
    case "$color" in
        red|r) echo -e "\033[31m$*\033[0m" ;;
        green|g) echo -e "\033[32m$*\033[0m" ;;
        yellow|y) echo -e "\033[33m$*\033[0m" ;;
        blue|b) echo -e "\033[34m$*\033[0m" ;;
        magenta|m) echo -e "\033[35m$*\033[0m" ;;
        cyan|c) echo -e "\033[36m$*\033[0m" ;;
        white|w) echo -e "\033[37m$*\033[0m" ;;
        *) echo "$*" ;;
    esac
}

# Bold, underline, reset macros
function bold() { echo -e "\033[1m$*\033[0m"; }
function underline() { echo -e "\033[4m$*\033[0m"; }
function success() { echo -e "\033[32m✅ SUCCESS: $*\033[0m"; }
function warning() { echo -e "\033[33m⚠️ WARNING: $*\033[0m"; }
function error() { echo -e "\033[31m❌ ERROR: $*\033[0m"; }

# Progress spinner during long operations
function spin() {
    local pid=$!
    local delay=0.1
    local spinstr='|/-\'
    while [ "$(ps a | awk '{print $1}' | grep $pid)" ]; do
        local temp=${spinstr#?}
        printf " [%c]  " "$spinstr"
        local spinstr=$temp${spinstr%"$temp"}
        sleep $delay
        printf "\b\b\b\b\b\b"
    done
    printf "    \b\b\b\b"
}

# Timestamp prefix for logging
function log_entry() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*"
}

# Safe cd that prints destination
function safe_cd() {
    if [ -d "$1" ]; then
        cd "$1" && echo "➡️ Now in: $(pwd)"
    else
        echo "❌ Directory doesn't exist: $1"
        return 1
    fi
}

# Count occurrences of something
function counter() {
    if [ $# -eq 0 ]; then
        echo "Count lines in stdin"
        wc -l
    elif [ $# -eq 1 ]; then
        echo "Lines in file: $1"
        wc -l "$1"
    else
        echo "Args: $@"
        eval "$*" | wc -l
    fi
}

# Make script executable properly
function make_exec() {
    if [ -z "$1" ]; then
        echo "Usage: make_exec <script_file>"
        return 1
    fi
    chmod +x "$1"
    echo "✅ Made executable: $1"
}

# Quick manual lookup (with fuzzy matching)
function manlook() {
    if [ -z "$1" ]; then
        echo "Usage: manlook <command>"
        return 1
    fi
    apropos "$1" | head -20
}

# Environment variables pretty print
function dump_env() {
    export | sort | nl
}

# Create symbolic link with confirmation
function createsym() {
    if [ $# -ne 2 ]; then
        echo "Usage: createsym <target> <link_name>"
        return 1
    fi
    ln -sf "$1" "$2"
    echo "✅ Symlink created: $2 -> $1"
}

# Validate URL syntax
function validurl() {
    local url_regex='^(https?:\/\/)?([\da-z.-]+)\.([a-z.]{2,6})([/\w .-]*)*\/?$'
    [[ "$1" =~ $url_regex ]] && echo "✅ Valid URL" || echo "❌ Invalid URL"
}

# Convert units
function convert_gb_mb() {
    echo "$1 GB = $(( $1 * 1024 )) MB"
}

# Human readable byte sizes
function bytes_to_hr() {
    num=$1
    if ((num >= 1073741824)); then
        echo "$(awk "BEGIN {printf \"%.2f\", $num/1073741824}") GB"
    elif ((num >= 1048576)); then
        echo "$(awk "BEGIN {printf \"%.2f\", $num/1048576}") MB"
    elif ((num >= 1024)); then
        echo "$(awk "BEGIN {printf \"%.2f\", $num/1024}") KB"
    else
        echo "$num Bytes"
    fi
}

