# Universal entpacken (unterstützt mehrere Formate)
function unpack() {
    if [ $# -eq 0 ]; then
        echo "Usage: unpack <archive_file>"
        echo "Supported formats: .tar.gz, .tgz, .tar.bz2, .tar.xz, .zip, .rar, .7z"
        return 1
    fi
    
    local file="$1"
    
    if [ ! -f "$file" ]; then
        echo "❌ Error: File '$file' not found"
        return 1
    fi
    
    case "$file" in
        *.tar.gz|*.tgz)
            echo "📦 Extracting .tar.gz ..."
            tar -xzvf "$file"
            ;;
        *.tar.bz2|*.tbz2)
            echo "📦 Extracting .tar.bz2 ..."
            tar -xjvf "$file"
            ;;
        *.tar.xz|*.txz)
            echo "📦 Extracting .tar.xz ..."
            tar -xJvf "$file"
            ;;
        *.tar)
            echo "📦 Extracting .tar ..."
            tar -xf "$file"
            ;;
        *.zip)
            echo "📦 Extracting .zip ..."
            unzip -q "$file"
            ;;
        *.rar)
            if command -v unrar &> /dev/null; then
                echo "📦 Extracting .rar ..."
                unrar x "$file"
            else
                echo "❌ unrar not installed. Run: sudo apt install unrar"
                return 1
            fi
            ;;
        *.7z)
            if command -v 7z &> /dev/null; then
                echo "📦 Extracting .7z ..."
                7z x -y "$file"
            else
                echo "❌ 7z not installed. Run: sudo apt install p7zip-full"
                return 1
            fi
            ;;
        *)
            echo "❌ Unknown archive format: $file"
            echo "Try installing extra tools for better support."
            return 1
            ;;
    esac
}

# Archive erstellen (Universal)
function pack() {
    if [ $# -lt 2 ]; then
        echo "Usage: pack <output_archive> <input_file_or_folder>"
        echo "Formats supported via extension: .tar.gz, .zip, .7z"
        return 1
    fi
    
    local output="$1"
    shift
    local input="$@"
    
    if [ ! -e "$input" ]; then
        echo "❌ Error: Input '$input' does not exist"
        return 1
    fi
    
    if [ -e "$output" ]; then
        echo "❌ Error: Output '$output' already exists!"
        return 1
    fi
    
    case "$output" in
        *.tar.gz|*.tgz)
            tar -czf "$output" "$input"
            echo "✅ Created: $output"
            ;;
        *.zip)
            zip -r "$output" "$input"
            echo "✅ Created: $output"
            ;;
        *.7z)
            if command -v 7z &> /dev/null; then
                7z a -t7z "$output" "$input"
                echo "✅ Created: $output"
            else
                echo "❌ 7z not installed"
                return 1
            fi
            ;;
        *)
            echo "❌ Unknown output format. Supported: .tar.gz, .zip, .7z"
            return 1
            ;;
    esac
}

# Komprimieren mit maximalem Level
function pack_hardcore() {
    if [ $# -lt 2 ]; then
        echo "Usage: pack_hardcore <output.7z> <input>"
        return 1
    fi
    
    local output="$1"
    shift
    local input="$@"
    
    [[ "$output" != *.7z ]] && output="${output}.7z"
    
    if [ ! -e "$input" ]; then
        echo "❌ Source does not exist"
        return 1
    fi
    
    7z a -t7z -mx=9 -m0=lzma2 -ms=on "$output" "$input"
    echo "✅ Hardcore compressed: $output"
}

# Archiv Inhalt ansehen ohne Entpacken
function archive_contents() {
    if [ $# -ne 1 ]; then
        echo "Usage: archive_contents <archive_file>"
        return 1
    fi
    
    case "$1" in
        *.tar.gz|*.tgz) tar -tzf "$1" ;;
        *.tar.bz2|*.tbz2) tar -tjf "$1" ;;
        *.tar.xz|*.txz) tar -tJf "$1" ;;
        *.zip) unzip -l "$1" ;;
        *.7z) 7z l "$1" ;;
        *) echo "Unknown format" ;;
    esac
}

